generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id        String   @id @default(cuid())
  discordId String   @unique
  username  String
  xp        Int      @default(0)
  level     Int      @default(1)
  rank      String   @default("Recruta")
  warnings  Int      @default(0)
  coins     Int      @default(0)
  gender    String   @default("NB")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  achievements      Achievement[]
  giveawayEntries   GiveawayEntry[]
  eventParticipants EventParticipant[]

  @@map("members")
}

model AllowedGuild {
  id        String   @id @default(cuid())
  guildId   String   @unique
  guildName String?
  addedBy   String
  note      String?
  active    Boolean  @default(true)
  addedAt   DateTime @default(now())

  @@map("allowed_guilds")
}

model BotManager {
  id        String   @id @default(cuid())
  userId    String   @unique
  username  String?
  addedBy   String
  addedAt   DateTime @default(now())

  @@map("bot_managers")
}

model ServerStat {
  id       String @id @default(cuid())
  guildId  String
  date     String
  joins    Int    @default(0)
  leaves   Int    @default(0)
  bans     Int    @default(0)
  messages Int    @default(0)

  @@unique([guildId, date])
  @@map("server_stats")
}

model Achievement {
  id          String   @id @default(cuid())
  memberId    String
  name        String
  description String?
  earnedAt    DateTime @default(now())

  member Member @relation(fields: [memberId], references: [discordId], onDelete: Cascade)

  @@unique([memberId, name])
  @@map("achievements")
}

model AchievementTemplate {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  description String
  xpReward    Int      @default(0)
  coinsReward Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([guildId, name])
  @@map("achievement_templates")
}

model Ticket {
  id        String    @id @default(cuid())
  channelId String    @unique
  authorId  String
  claimedBy String?
  category  String    @default("geral")
  status    String    @default("open")
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  @@map("tickets")
}

model Warn {
  id        String   @id @default(cuid())
  memberId  String
  moderator String
  reason    String
  guildId   String
  createdAt DateTime @default(now())

  @@map("warns")
}

model Poll {
  id        String      @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  question  String
  createdBy String
  endsAt    DateTime?
  ended     Boolean     @default(false)
  createdAt DateTime    @default(now())

  options PollOption[]

  @@map("polls")
}

model PollOption {
  id     String   @id @default(cuid())
  pollId String
  label  String
  votes  Int      @default(0)
  voters String[] @default([])

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@map("poll_options")
}

model Giveaway {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  prize     String
  winners   Int      @default(1)
  hostId    String
  endsAt    DateTime
  ended     Boolean  @default(false)
  winnerIds String[] @default([])
  createdAt DateTime @default(now())

  entries GiveawayEntry[]

  @@map("giveaways")
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  memberId   String
  joinedAt   DateTime @default(now())

  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([giveawayId, memberId])
  @@map("giveaway_entries")
}

model Event {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?
  title       String
  description String?
  hostId      String
  startsAt    DateTime
  ended       Boolean  @default(false)
  createdAt   DateTime @default(now())

  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id       String   @id @default(cuid())
  eventId  String
  memberId String
  joinedAt DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@map("event_participants")
}

model ShopItem {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  description String
  price       Int
  roleId      String?
  stock       Int      @default(-1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  purchases ShopPurchase[]

  @@unique([guildId, name])
  @@map("shop_items")
}

model ShopPurchase {
  id       String   @id @default(cuid())
  itemId   String
  memberId String
  guildId  String
  boughtAt DateTime @default(now())

  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("shop_purchases")
}

model DailyMission {
  id         String  @id @default(cuid())
  memberId   String
  guildId    String
  type       String
  target     Int
  progress   Int     @default(0)
  completed  Boolean @default(false)
  claimed    Boolean @default(false)
  xpReward   Int
  coinReward Int
  dateStr    String

  @@unique([memberId, guildId, type, dateStr])
  @@map("daily_missions")
}

// ─── NOVO: Missões Semanais ───────────────────────────────────────────

model WeeklyMission {
  id         String  @id @default(cuid())
  memberId   String
  guildId    String
  type       String
  target     Int
  progress   Int     @default(0)
  completed  Boolean @default(false)
  claimed    Boolean @default(false)
  xpReward   Int
  coinReward Int
  weekStr    String

  @@unique([memberId, guildId, type, weekStr])
  @@map("weekly_missions")
}

model GuildConfig {
  id                    String   @id @default(cuid())
  guildId               String   @unique
  logChannelId          String?
  welcomeChannelId      String?
  announcementChannelId String?
  ticketCategoryId      String?
  ticketLogChannelId    String?
  adminRoleId           String?
  modRoleId             String?
  memberRoleId          String?
  mutedRoleId           String?
  levelUpChannelId      String?
  suggestionChannelId   String?
  feedbackChannelId     String?
  autoRoleId            String?
  welcomeMessage        String?
  xpMin                 Int      @default(15)
  xpMax                 Int      @default(25)
  xpCooldown            Int      @default(60)
  antiSpam              Boolean  @default(false)
  antiLinks             Boolean  @default(false)
  logFlags              Int      @default(31)
  updatedAt             DateTime @updatedAt @default(now())

  @@map("guild_config")
}

model LevelReward {
  id      String  @id @default(cuid())
  guildId String
  level   Int
  roleId  String?
  coins   Int     @default(0)

  @@unique([guildId, level])
  @@map("level_rewards")
}

// ═══════════════════════════════════════════════════════════════════════
// RPG MODELS
// ═══════════════════════════════════════════════════════════════════════

model RpgCharacter {
  discordId     String   @id
  username      String
  class         String   @default("guerreiro")
  level         Int      @default(1)
  xp            Int      @default(0)
  generation    Int      @default(1)
  gold          Int      @default(100)

  currentHp     Int      @default(100)
  maxHp         Int      @default(100)
  currentEnergy Int      @default(50)
  maxEnergy     Int      @default(50)

  strength      Int      @default(10)
  agility       Int      @default(10)
  intelligence  Int      @default(10)
  vitality      Int      @default(10)
  luck          Int      @default(10)

  statPoints    Int      @default(0)
  skillPoints   Int      @default(0)

  divineSkillId   String?
  divineSkillRank String  @default("F")
  divineSkillExp  Int     @default(0)

  currentLocation String  @default("cidade_inicial")
  environment     String  @default("DIA")

  karma         Int     @default(0)
  pvpEnabled    Boolean @default(true)
  pvpWins       Int     @default(0)
  pvpLosses     Int     @default(0)

  totalKills    Int     @default(0)
  totalDeaths   Int     @default(0)
  totalWins     Int     @default(0)
  bossKills     Int     @default(0)

  lastDungeon    DateTime?
  lastTravel     DateTime?
  lastPvp        DateTime?
  lastRest       DateTime?
  lastEnergyTick DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  equipment       RpgEquipment?
  inventory       RpgInventoryItem[]
  guildMembership RpgGuildMember?
  learnedSkills   RpgLearnedSkill[]
  combatLogs      RpgCombatLog[]
  craftQueue      RpgCraftQueue[]

  @@map("rpg_characters")
}

model RpgEquipment {
  characterId String  @id
  weapon      String?
  helmet      String?
  pants       String?
  boots       String?
  gloves      String?
  shield      String?
  ring        String?
  amulet      String?
  backpack    String?
  pet         String?
  character   RpgCharacter @relation(fields: [characterId], references: [discordId], onDelete: Cascade)

  @@map("rpg_equipment")
}

model RpgInventoryItem {
  id          String   @id @default(cuid())
  characterId String
  itemId      String
  quantity    Int      @default(1)
  obtainedAt  DateTime @default(now())
  character   RpgCharacter @relation(fields: [characterId], references: [discordId], onDelete: Cascade)

  @@unique([characterId, itemId])
  @@map("rpg_inventory")
}

model RpgGuild {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String   @unique
  emblem      String   @default("⚔️")
  description String?
  leaderId    String
  level       Int      @default(1)
  xp          Int      @default(0)
  gold        Int      @default(0)
  maxMembers  Int      @default(20)
  announcement String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     RpgGuildMember[]

  @@map("rpg_guilds")
}

model RpgGuildMember {
  id          String   @id @default(cuid())
  characterId String   @unique
  guildId     String
  role        String   @default("Membro")
  joinedAt    DateTime @default(now())
  character   RpgCharacter @relation(fields: [characterId], references: [discordId], onDelete: Cascade)
  guild       RpgGuild     @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@map("rpg_guild_members")
}

model RpgLearnedSkill {
  id          String   @id @default(cuid())
  characterId String
  skillId     String
  rank        String   @default("F")
  exp         Int      @default(0)
  learnedAt   DateTime @default(now())
  character   RpgCharacter @relation(fields: [characterId], references: [discordId], onDelete: Cascade)

  @@unique([characterId, skillId])
  @@map("rpg_learned_skills")
}

model RpgCombatLog {
  id          String   @id @default(cuid())
  characterId String
  type        String
  result      String
  enemyName   String?
  opponentId  String?
  xpGained    Int      @default(0)
  goldGained  Int      @default(0)
  itemsGained String[] @default([])
  rounds      Int      @default(0)
  summary     String?
  createdAt   DateTime @default(now())
  character   RpgCharacter @relation(fields: [characterId], references: [discordId], onDelete: Cascade)

  @@map("rpg_combat_logs")
}

model RpgCraftQueue {
  id          String   @id @default(cuid())
  characterId String
  recipeId    String
  startedAt   DateTime @default(now())
  completesAt DateTime
  collected   Boolean  @default(false)
  character   RpgCharacter @relation(fields: [characterId], references: [discordId], onDelete: Cascade)

  @@map("rpg_craft_queue")
}

model RpgShopRotation {
  id        String   @id @default(cuid())
  itemId    String
  price     Int
  stock     Int      @default(-1)
  sold      Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("rpg_shop_rotation")
}

// ─── NOVO: Boss Mundial ───────────────────────────────────────────────

model WorldBoss {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  emoji       String   @default("🐉")
  description String?
  maxHp       Int
  currentHp   Int
  level       Int      @default(1)
  status      String   @default("active")
  xpReward    Int
  goldReward  Int
  spawnedAt   DateTime @default(now())
  defeatedAt  DateTime?
  expiresAt   DateTime

  participants WorldBossParticipant[]

  @@map("world_bosses")
}

model WorldBossParticipant {
  id          String   @id @default(cuid())
  bossId      String
  discordId   String
  username    String
  damageDealt Int      @default(0)
  hits        Int      @default(0)
  lastHit     DateTime?

  boss WorldBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)

  @@unique([bossId, discordId])
  @@map("world_boss_participants")
}

// ─── NOVO: Casamento ──────────────────────────────────────────────────

model Marriage {
  id        String   @id @default(cuid())
  userId1   String
  userId2   String
  marriedAt DateTime @default(now())

  @@unique([userId1, userId2])
  @@map("marriages")
}

model MarriageProposal {
  id         String   @id @default(cuid())
  proposerId String
  targetId   String
  guildId    String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@unique([proposerId, targetId])
  @@map("marriage_proposals")
}

// ─── Aliança Skyline ──────────────────────────────────────────────────

model AllianceServer {
  id          String   @id @default(cuid())
  guildId     String   @unique
  guildName   String?
  memberCount Int      @default(0)
  class       String   @default("Sem Classe")
  channelId   String?
  inviteLink  String?
  addedBy     String
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members AllianceServerMember[]

  @@map("alliance_servers")
}

model AllianceServerMember {
  id       String   @id @default(cuid())
  guildId  String
  userId   String
  username String?
  role     String
  addedAt  DateTime @default(now())

  server AllianceServer @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, userId])
  @@map("alliance_server_members")
}

model AllianceBlacklist {
  id       String   @id @default(cuid())
  userId   String   @unique
  username String?
  reason   String?
  addedBy  String
  addedAt  DateTime @default(now())

  @@map("alliance_blacklist")
}

model AllianceEmbed {
  id        String   @id @default(cuid())
  guildId   String   @unique
  channelId String
  messageId String
  updatedAt DateTime @updatedAt

  @@map("alliance_embeds")
}

// ═══════════════════════════════════════════════════════════════════════
// BOT GLOBAL CONFIG
// ═══════════════════════════════════════════════════════════════════════

model BotConfig {
  id           String   @id @default("global")
  footerText   String   @default("⚔️ Aliança Skyline")
  primaryColor Int      @default(10180278)
  botIconUrl   String?
  rpFooterText String   @default("⚔️ Aliança Skyline • /genero para mudar seus pronomes")
  updatedAt    DateTime @updatedAt @default(now())

  @@map("bot_config")
}

model EmbedTemplate {
  key          String   @id
  title        String?
  description  String?
  color        Int?
  thumbnailUrl String?
  imageUrl     String?
  footerText   String?
  footerIcon   String?
  updatedAt    DateTime @updatedAt @default(now())

  @@map("embed_templates")
}

model SelfRoleMenu {
  id          String          @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?
  title       String          @default("📋 Registro de Cargos")
  description String?
  entries     SelfRoleEntry[]
  createdAt   DateTime        @default(now())

  @@map("self_role_menus")
}

model SelfRoleEntry {
  id     String       @id @default(cuid())
  menuId String
  menu   SelfRoleMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  roleId String
  label  String
  emoji  String?

  @@map("self_role_entries")
}
