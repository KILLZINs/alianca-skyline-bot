generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id        String   @id @default(cuid())
  discordId String   @unique
  username  String
  xp        Int      @default(0)
  level     Int      @default(1)
  rank      String   @default("Recruta")
  warnings  Int      @default(0)
  coins     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  achievements      Achievement[]
  giveawayEntries   GiveawayEntry[]
  eventParticipants EventParticipant[]

  @@map("members")
}

// Achievements earned by a specific member
model Achievement {
  id          String   @id @default(cuid())
  memberId    String
  name        String
  description String?
  earnedAt    DateTime @default(now())

  member Member @relation(fields: [memberId], references: [discordId], onDelete: Cascade)

  @@unique([memberId, name])
  @@map("achievements")
}

// Templates defined by admins per guild
model AchievementTemplate {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  description String
  xpReward    Int      @default(0)
  coinsReward Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([guildId, name])
  @@map("achievement_templates")
}

model Ticket {
  id        String    @id @default(cuid())
  channelId String    @unique
  authorId  String
  claimedBy String?
  category  String    @default("geral")
  status    String    @default("open")
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  @@map("tickets")
}

model Warn {
  id        String   @id @default(cuid())
  memberId  String
  moderator String
  reason    String
  guildId   String
  createdAt DateTime @default(now())

  @@map("warns")
}

model Poll {
  id        String      @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  question  String
  createdBy String
  endsAt    DateTime?
  ended     Boolean     @default(false)
  createdAt DateTime    @default(now())

  options PollOption[]

  @@map("polls")
}

model PollOption {
  id     String   @id @default(cuid())
  pollId String
  label  String
  votes  Int      @default(0)
  voters String[] @default([])

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@map("poll_options")
}

model Giveaway {
  id        String   @id @default(cuid())
  guildId   String
  channelId String
  messageId String?
  prize     String
  winners   Int      @default(1)
  hostId    String
  endsAt    DateTime
  ended     Boolean  @default(false)
  winnerIds String[] @default([])
  createdAt DateTime @default(now())

  entries GiveawayEntry[]

  @@map("giveaways")
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  memberId   String
  joinedAt   DateTime @default(now())

  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([giveawayId, memberId])
  @@map("giveaway_entries")
}

model Event {
  id          String   @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?
  title       String
  description String?
  hostId      String
  startsAt    DateTime
  ended       Boolean  @default(false)
  createdAt   DateTime @default(now())

  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id       String   @id @default(cuid())
  eventId  String
  memberId String
  joinedAt DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
  @@map("event_participants")
}

model GuildConfig {
  id                    String   @id @default(cuid())
  guildId               String   @unique
  logChannelId          String?
  welcomeChannelId      String?
  announcementChannelId String?
  ticketCategoryId      String?
  ticketLogChannelId    String?
  adminRoleId           String?
  modRoleId             String?
  memberRoleId          String?
  mutedRoleId           String?
  levelUpChannelId      String?
  suggestionChannelId   String?
  feedbackChannelId     String?
  updatedAt             DateTime @updatedAt @default(now())

  @@map("guild_config")
}
